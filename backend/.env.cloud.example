SPRING_PROFILES_ACTIVE=prod
CORS_ORIGINS=https://goldeninfinity.com,https://www.goldeninfinity.com

# Neon PostgreSQL
DB_URL=jdbc:postgresql://YOUR_NEON_HOST/YOUR_DATABASE?sslmode=require
DB_APP_USER=YOUR_NEON_USER
DB_APP_PASSWORD=YOUR_NEON_PASSWORD

# Upstash Redis
REDIS_HOST=YOUR_UPSTASH_REDIS_HOST
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_UPSTASH_REDIS_PASSWORD
REDIS_SSL_ENABLED=true

# Security
PII_ENCRYPTION_KEY=CHANGE_TO_A_LONG_RANDOM_SECRET
RATE_LIMIT_ENABLED=true

# Appointment email notifications
APPOINTMENT_EMAIL_ENABLED=false
NOTIFICATION_FROM=admin@goldeninfinityph.com
APPOINTMENT_STAFF_EMAIL=admin@goldeninfinityph.com

# SMTP for cPanel/Roundcube mailbox
SMTP_HOST=mail.goldeninfinityph.com
SMTP_PORT=465
SMTP_USERNAME=admin@goldeninfinityph.com
SMTP_PASSWORD=YOUR_CPANEL_EMAIL_PASSWORD
SMTP_SSL=true
SMTP_STARTTLS=false
SMTP_AUTH=true
